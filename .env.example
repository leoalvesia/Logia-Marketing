# === BACKEND ===
SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=sqlite+aiosqlite:///./logia.db
# DATABASE_URL=postgresql+asyncpg://logia:logia@postgres:5432/logia
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
BUILD_SHA=dev

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === PUBLICAÇÃO — Instagram (Meta Graph API) ===
META_ACCESS_TOKEN=...
META_INSTAGRAM_ACCOUNT_ID=...

# === PUBLICAÇÃO — Twitter/X (OAuth 1.0a) ===
TWITTER_CONSUMER_KEY=...
TWITTER_CONSUMER_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...

# === PUBLICAÇÃO — LinkedIn (OAuth 2.0) ===
LINKEDIN_ACCESS_TOKEN=...
LINKEDIN_PERSON_ID=urn:li:person:XXXXXXXX

# === EMAIL (Resend) ===
RESEND_API_KEY=re_...
EMAIL_FROM=newsletter@seudominio.com

# === COLETA DE DADOS ===
APIFY_TOKEN=...
YOUTUBE_API_KEY=...
RAPIDAPI_KEY=...

# === GOOGLE (Drive + YouTube) ===
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-sa.json
GOOGLE_DRIVE_FOLDER_ID=...

# === GERAÇÃO DE IMAGEM ===
# DALL-E usa OPENAI_API_KEY acima
STABILITY_AI_KEY=...

# === CRIPTOGRAFIA DE TOKENS ===
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === ALERTAS ===
# Webhook do Slack para alertas de backup (opcional)
SLACK_WEBHOOK=

# === OBSERVABILIDADE ===
# Obter em: https://sentry.io → Projeto → Settings → Client Keys (DSN)
SENTRY_DSN=
# Frontend — variáveis expostas ao browser (prefixo VITE_ obrigatório)
VITE_SENTRY_DSN=
VITE_ENVIRONMENT=development
VITE_BUILD_SHA=dev
