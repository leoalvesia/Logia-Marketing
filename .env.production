# =============================================================================
# Logia Marketing Platform — Variáveis de Produção
# TEMPLATE — substitua todos os valores PLACEHOLDER antes de usar
# NUNCA commitar este arquivo com valores reais no Git
# =============================================================================

# ------------------------------------------------------------------------------
# SEGURANÇA
# Gerar com: openssl rand -hex 32
# ------------------------------------------------------------------------------
SECRET_KEY=PLACEHOLDER_openssl_rand_hex_32

# ------------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# Use senha forte: openssl rand -base64 24
# No VPS: /opt/logia/shared/postgres-data é o volume
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://logia:PLACEHOLDER_SENHA_POSTGRES@postgres:5432/logia_prod

# ------------------------------------------------------------------------------
# REDIS
# Sem senha em rede Docker interna (isolada de portas externas)
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# CORS / HOSTS
# Separar múltiplos por vírgula se necessário
# ------------------------------------------------------------------------------
ALLOWED_ORIGINS=https://app.logia.com.br
ALLOWED_HOSTS=app.logia.com.br

# ------------------------------------------------------------------------------
# LLM — Anthropic (Claude) e OpenAI
# Obter em: https://console.anthropic.com | https://platform.openai.com
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=PLACEHOLDER_sk-ant-...
OPENAI_API_KEY=PLACEHOLDER_sk-...

# ------------------------------------------------------------------------------
# PUBLICAÇÃO — Instagram (Meta Graph API)
# Obter em: https://developers.facebook.com → Meu App → Token de acesso
# META_INSTAGRAM_ACCOUNT_ID: ID numérico da conta profissional Instagram
# ------------------------------------------------------------------------------
META_ACCESS_TOKEN=PLACEHOLDER_token_meta
META_INSTAGRAM_ACCOUNT_ID=PLACEHOLDER_id_numerico

# ------------------------------------------------------------------------------
# PUBLICAÇÃO — Twitter / X (OAuth 1.0a)
# Obter em: https://developer.twitter.com → Projects & Apps → Keys and Tokens
# Necessário nível "Elevated" ou "Free" com permissão de escrita
# ------------------------------------------------------------------------------
TWITTER_CONSUMER_KEY=PLACEHOLDER_consumer_key
TWITTER_CONSUMER_SECRET=PLACEHOLDER_consumer_secret
TWITTER_ACCESS_TOKEN=PLACEHOLDER_access_token
TWITTER_ACCESS_TOKEN_SECRET=PLACEHOLDER_access_token_secret

# ------------------------------------------------------------------------------
# PUBLICAÇÃO — LinkedIn (OAuth 2.0)
# Obter em: https://www.linkedin.com/developers → Apps → Auth
# LINKEDIN_PERSON_ID: urn:li:person:XXXXXXXX (retornado pelo endpoint /v2/me)
# ------------------------------------------------------------------------------
LINKEDIN_ACCESS_TOKEN=PLACEHOLDER_linkedin_token
LINKEDIN_PERSON_ID=urn:li:person:PLACEHOLDER

# ------------------------------------------------------------------------------
# EMAIL — Resend (transacional)
# Obter em: https://resend.com → API Keys
# EMAIL_FROM deve ser um domínio verificado no Resend
# ------------------------------------------------------------------------------
RESEND_API_KEY=PLACEHOLDER_re_...
EMAIL_FROM=newsletter@logia.com.br

# ------------------------------------------------------------------------------
# COLETA DE DADOS
# Apify: https://console.apify.com → Settings → Integrations → API Tokens
# YouTube Data API: https://console.cloud.google.com → APIs → YouTube Data API v3
# RapidAPI: https://rapidapi.com → Apps → Add New App → Security
# ------------------------------------------------------------------------------
APIFY_TOKEN=PLACEHOLDER_apify_token
YOUTUBE_API_KEY=PLACEHOLDER_yt_api_key
RAPIDAPI_KEY=PLACEHOLDER_rapidapi_key

# ------------------------------------------------------------------------------
# GOOGLE (Drive + Service Account)
# 1. Criar Service Account: https://console.cloud.google.com → IAM → Service Accounts
# 2. Criar chave JSON → baixar → colocar em /opt/logia/shared/credentials/google-sa.json
# 3. Compartilhar a pasta do Drive com o e-mail da Service Account (Editor)
# GOOGLE_DRIVE_FOLDER_ID: ID da URL da pasta no Google Drive
# ------------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=/credentials/google-sa.json
GOOGLE_DRIVE_FOLDER_ID=PLACEHOLDER_folder_id

# ------------------------------------------------------------------------------
# GERAÇÃO DE IMAGEM — Stability AI (opcional se usando só DALL-E)
# Obter em: https://platform.stability.ai → API Keys
# ------------------------------------------------------------------------------
STABILITY_AI_KEY=PLACEHOLDER_stability_key

# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DO SERVIDOR (não alterar em produção normal)
# ------------------------------------------------------------------------------
ENVIRONMENT=production
LOG_LEVEL=info
# Número de workers uvicorn (regra: 2 * CPU cores + 1)
UVICORN_WORKERS=4
# Injetado automaticamente pelo CI/CD (BUILD_SHA = github.sha)
BUILD_SHA=PLACEHOLDER_sera_injetado_pelo_ci

# ------------------------------------------------------------------------------
# CRIPTOGRAFIA DE TOKENS OAUTH
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=PLACEHOLDER_gerar_com_fernet

# ALERTAS
# Webhook do Slack: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK=PLACEHOLDER_https://hooks.slack.com/services/...

# ADMIN (beta launch)
# Gerar com: openssl rand -hex 24
ADMIN_KEY=PLACEHOLDER_openssl_rand_hex_24

# FEATURE FLAGS (false = desabilitado, true = habilitado)
FF_CAROUSEL=false
FF_THUMBNAIL=false
FF_LINKEDIN=true
FF_YOUTUBE_RESEARCH=true

# OBSERVABILIDADE — Sentry
# Criar projeto em https://sentry.io → Add Project → FastAPI (backend) + React (frontend)
# DSN é diferente para backend e frontend
# ------------------------------------------------------------------------------
SENTRY_DSN=PLACEHOLDER_https://xxx@oxx.ingest.sentry.io/PROJETO_BACKEND

# Frontend (variáveis VITE_ são embarcadas no build do React)
VITE_SENTRY_DSN=PLACEHOLDER_https://xxx@oxx.ingest.sentry.io/PROJETO_FRONTEND
VITE_ENVIRONMENT=production
# VITE_BUILD_SHA é injetado pelo build-arg no Dockerfile (não definir aqui)
